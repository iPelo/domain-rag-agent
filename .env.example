APP_ENV=local
DOMAIN_NAME=GermanLawRAG

API_HOST=0.0.0.0
API_PORT=8000

QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=german_law_chunks

DATA_RAW_DIR=data/raw/german-laws
DATA_PROCESSED_DIR=data/processed
INDEX_CHUNKS_PATH=data/processed/chunks.curated.jsonl

EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024
EMBEDDING_BATCH_SIZE=32
EMBEDDING_DEVICE=
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

RETRIEVAL_DEFAULT_TOP_K=5
RETRIEVAL_CANDIDATE_POOL=30

LLM_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
