{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "GermanLawRAG: Build Retrieval Index",
      "type": "shell",
      "command": "docker compose up -d qdrant && uv run python scripts/build_index.py",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "GermanLawRAG: Run Retrieval Evaluation",
      "type": "shell",
      "command": "uv run python scripts/run_eval.py",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "dedicated",
        "clear": true
      }
    }
  ]
}
